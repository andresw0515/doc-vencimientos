# ====================================================
# DOC VENCIMIENTOS — Variables de Entorno
# ====================================================
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git (ya está en .gitignore)
# ====================================================

# --- Base de Datos PostgreSQL ---
DATABASE_URL=postgresql://usuario:password@host:5432/doc_vencimientos

# --- Seguridad JWT ---
# Genera un valor seguro con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_un_valor_seguro_generado_con_openssl

# --- Resend (Email) ---
# Obtén tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tuidominio.com
EMAIL_FROM_NAME=Doc Vencimientos

# --- Aplicación ---
APP_URL=https://tu-app.onrender.com
ENVIRONMENT=production

# --- Alertas (días antes de vencer) ---
# No modificar en producción a menos que sea necesario
# ALERT_DAYS_BEFORE=[30,15,7,3,1]
